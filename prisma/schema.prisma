generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  passwordHash  String?
  role          String    @default("ADMIN")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Car {
  id            String    @id @default(cuid())
  name          String
  brand         String
  type          String    // e.g. "Commercial", "Private"
  mileage       String
  fuel          String
  seats         Int
  price         Float
  expectedEmi   Float
  images        String    // JSON array string of Cloudinary URLs
  features      String    // JSON array string of features
  isPublished   Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Lead {
  id            String    @id @default(cuid())
  name          String
  phone         String
  type          String    // e.g. "Finance", "Purchase", "Fleet", "Business"
  status        String    @default("NEW") // "NEW", "CONTACTED", "CLOSED"
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Testimonial {
  id            String    @id @default(cuid())
  name          String
  content       String
  mediaUrl      String?   // Video or image URL
  isPublished   Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
